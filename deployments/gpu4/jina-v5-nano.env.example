COMPOSE_PROJECT_NAME=embedding-provider-jina-v5-nano
SERVICE_NAME=jina-v5-nano
BIND_HOST=100.93.145.69
PORT=7997
API_KEY=change-me
HF_CACHE_DIR=./runtime-cache/jina-v5-nano
CUDA_VISIBLE_DEVICES=0
SHM_SIZE=2g
PUBLIC_HOSTNAME=
PUBLIC_BIND=
PUBLIC_UPSTREAM=127.0.0.1:7997

MODEL_ID=jinaai/jina-embeddings-v5-text-nano
MODEL_ALIAS=jinaai/jina-embeddings-v5-text-nano
EMBEDDING_TASK=text-matching
DEFAULT_DIMENSIONS=768
MAX_LENGTH=8192
MAX_BATCH_SIZE=64
BATCH_WINDOW_MS=200
IDLE_OFFLOAD_SECONDS=1800
IDLE_OFFLOAD_POLL_SECONDS=30
NORMALIZE_EMBEDDINGS=true
DTYPE=bfloat16
ATTN_IMPLEMENTATION=
TRUST_REMOTE_CODE=true
